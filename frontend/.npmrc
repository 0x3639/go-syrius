# Supply-chain policy: refuse to install package versions published less than
# 7 days (10080 minutes) ago, to avoid freshly-compromised releases.
# Requires pnpm >= 10.16 (see "packageManager" in package.json: pnpm@10.17.1).
# The authoritative value also lives in package.json -> pnpm.minimumReleaseAge.
minimum-release-age=10080
